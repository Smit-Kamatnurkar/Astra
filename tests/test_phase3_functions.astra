// Astra Test: Phase 3 — Advanced Functions

// --- 1. Default Parameters ---
fn greetUser(str->name, int->times = 1) -> void {
    mut int->i = 0;
    while (i < times) {
        output(name);
        i = i + 1;
    }
}

// --- 2. Multiple defaults ---
fn compute(int->a, int->b = 10, int->c = 20) -> int {
    return a + b + c;
}

// --- 3. Extern function (C library) ---
extern fn abs(int->x) -> int;

fn main() -> int {
    // Test default params: use all args
    greetUser("Hello", 2);

    // Test default params: omit last arg
    greetUser("World");

    // Test multiple defaults: all args
    output(compute(1, 2, 3));    // 6

    // Test multiple defaults: omit last
    output(compute(1, 2));       // 23

    // Test multiple defaults: omit both
    output(compute(5));          // 35

    // Test extern fn (C abs)
    output(abs(0 - 42));         // 42
    output(abs(10));             // 10

    output("Phase 3 tests passed!");
    return 0;
}

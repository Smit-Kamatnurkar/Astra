// Astra Test: Phase 5 — OOP (Struct Methods)

struct Counter {
    int->value;
}

impl Counter {
    fn increment() -> void {
        self.value = self.value + 1;
    }

    fn decrement() -> void {
        self.value = self.value - 1;
    }

    fn getValue() -> int {
        return self.value;
    }

    fn addN(int->n) -> void {
        self.value = self.value + n;
    }
}

struct Circle {
    f64->radius;
}

impl Circle {
    fn area() -> f64 {
        return 3.14159 * self.radius * self.radius;
    }

    fn scale(f64->factor) -> void {
        self.radius = self.radius * factor;
    }
}

fn main() -> int {
    // --- 1. Basic method call ---
    mut Counter->c;
    c.value = 0;
    c.increment();
    output(c.getValue());   // 1

    c.increment();
    c.increment();
    output(c.getValue());   // 3

    // --- 2. Method with parameter ---
    c.addN(10);
    output(c.getValue());   // 13

    // --- 3. Decrement ---
    c.decrement();
    output(c.getValue());   // 12

    // --- 4. Another struct with methods ---
    mut Circle->circle;
    circle.radius = 5.0;
    output(circle.area());  // ~78.5

    // --- 5. Method modifying fields ---
    circle.scale(2.0);
    output(circle.radius);  // 10.0

    output("Phase 5 tests passed!");
    return 0;
}
